# Copia este archivo como .env y completa los valores (NO subas .env a git)

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # secreta, solo backend
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=your-jwt-secret                    # Settings → API → JWT Secret

# --- App ---
ENVIRONMENT=production                         # 'development' habilita /debug
CORS_ORIGINS=https://tu-frontend.example.com
FRONTEND_URL=https://tu-frontend.example.com # para el enlace de recuperación de clave
# Dominio(s) del BACKEND (no el frontend) separados por coma — ej: api.tudominio.com.
# Deja "*" solo en desarrollo; en producción hay que poner el dominio real, si no
# TrustedHostMiddleware acepta cualquier Host y no protege nada.
ALLOWED_HOSTS=*
MAX_IPS_POR_USUARIO=3

# --- Cifrado de credenciales SRI (OBLIGATORIO) ---
# Sin esta clave, el módulo de credenciales (guardar/revelar claves SRI) lanza
# RuntimeError. Genérala con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_MASTER_KEY=
# Rotación de llaves (opcional): al rotar, la nueva va en _V2, _V3, ... y la
# anterior se mantiene en CREDENTIALS_MASTER_KEY para poder descifrar lo viejo.
# CREDENTIALS_MASTER_KEY_V2=

# --- Odoo 19 (facturación de honorarios; routers/odoo_factura.py) ---
ODOO_URL=https://tu-empresa.odoo.com
ODOO_DB=tu-empresa
ODOO_USERNAME=usuario@ejemplo.com
ODOO_API_KEY=
ODOO_NOTIFY_EMAIL=
ODOO_EXCLUIR_EMISOR=            # RUC(s) emisor a excluir (opcional)
CRON_SECRET=                    # protege el endpoint de sincronización por cron

# --- Mistral AI (lectura IA de documentos en rebajas; services/doc_ia.py) ---
MISTRAL_API_KEY=

# --- Observabilidad (Sentry) — opcional; si se deja vacío, Sentry queda desactivado ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# --- SMTP (envío de notificaciones; services/email_sender.py) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ADMIN_EMAIL=                    # destino de avisos administrativos
